=== automated_player_helm_ai
    # default assignment  
    default last = None
    default last_go_dock = False

    # Re get ship if respawn occured
    ship = to_object(_ship_id)
    #
    # 
    #
    #if ship is None:
    #    await task_schedule(automated_player_respawn)
    if ship is None:
        print("Autoplayer is no more")
        ->END
        
    # Foes = raider-tagged ships still HOSTILE to this autoplayer's side (diplomacy),
    # so a ceasefired/neutral clan or a surrendered ship is not chased.
    _foes = side_hostile_members(_ship_id, "raider")
    raider = to_object(closest(_ship_id, _foes))
    close_raider = to_object(closest(_ship_id, _foes, 10000))
    station = to_object(closest(_ship_id, side_allied_members(_ship_id, "station")))
    danger = to_object(closest(_ship_id, any_role("mine,maelstrom"), 2500))
    upgrade = to_object(closest(_ship_id, all_roles("upgrade"), 5000))
    wreck = to_object(closest(_ship_id, all_roles("wreck"), 7500))


    energy = ship.data_set.get("energy", 0)
    if energy < 30:
        energy = 300
        ship.data_set.set("energy", energy, 0)

    f_shld = ship.data_set.get("shield_val", 0)
    f_shld_max = ship.data_set.get("shield_max_val", 0)
    r_shld = ship.data_set.get("shield_val", 1)
    r_shld_max = ship.data_set.get("shield_max_val", 1)

    if not last_go_dock:
        go_dock = ((f_shld/f_shld_max)< 0.3) 
        go_dock = go_dock or ((r_shld/r_shld_max)< 0.3)
        go_dock =  go_dock or energy < 300
        if go_dock:
            last_go_dock = True
    else:
        un_dock = f_shld>= f_shld_max and f_shld>= f_shld_max and energy >= 1000
        if un_dock:
            ship.data_set.set("dock_state", "undocked",0)
            go_dock = False
            last_go_dock = False

    # go_dock
    #    either shield < 50
    #    or energy < 300 

    if go_dock:
        t = station
    elif close_raider is not None:
        t = close_raider
    elif upgrade is not None:
        t = upgrade
    elif wreck is not None: 
        t = wreck
    else:
        t = raider

    # Can we still steer? Consult BOTH the turn damage coeff AND the engineering maneuver
    # subsystem's damage - a wrecked maneuver system means we cannot turn even before the
    # coeff bottoms out. When we cannot turn we must not burn straight ahead (see below).
    turn_coeff = ship.data_set.get("turn_damage_coeff", 1) or 1
    maneuver_dmg = 0.0
    for _mi in range(30):
        _mlbl = ship.data_set.get("eng_control_label", _mi)
        continue if _mlbl is None or _mlbl == ""
        if "maneuver" in _mlbl.lower():
            _msys = ship.data_set.get("eng_control_type_index", _mi) or 0
            _mmax = ship.data_set.get("system_max_damage", _msys) or 0
            _mcur = ship.data_set.get("system_damage", _msys) or 0
            if _mmax > 0:
                maneuver_dmg = _mcur / _mmax
    can_turn = turn_coeff >= 0.35 and maneuver_dmg < 0.75


    if t is not None:
        diff =  t.pos - ship.pos
        ln = diff.length()

        if danger is not None:
            danger_diff =  danger.pos - ship.pos
            danger_ln = danger_diff.length()
            if ln > danger_ln:
                move = Vec3(ship.pos)
                old = move.y
                move.y = danger.pos.y
                if t.pos.y > danger.pos.y:
                    ~~move.y += 1200~~
                else:
                    ~~move.y -= 1200~~
                if move.y != old:
                    ship.pos = move
            elif ln < 2000:
                move = Vec3(ship.pos)
                old = move.y
                move.y = t.pos.y
                if move.y != old:
                    ship.pos = move
        #
        #
        if ln < 700 and has_roles(t, "tsn, station") and last_go_dock:
            ship.data_set.set("dock_base_id", to_id(t))
            state = ship.data_set.get("dock_state",0)
            if state != "docked" and state != "dock_start":
                ship.data_set.set("dock_state", "dock_start",0)
            ship.data_set.set("playerThrottle", 0,0)
            speed = 0
        elif ln < 700 and has_roles(t, "raider"):
            ship.data_set.set("playerThrottle", 0,0)
            speed = 0
        elif ln < 1000:
            speed = ln/1000
            ship.data_set.set("playerThrottle", speed,0)
        elif ln < 5000:
            ship.data_set.set("playerThrottle", 1.0,0)
            speed = 1.0
        elif ln < 10000:
            ship.data_set.set("playerThrottle", 2.0,0)
            speed = 2.0
        elif ln < 20000:
            ship.data_set.set("playerThrottle", 3.0,0)
            speed = 3
        elif ln < 30000:
            ship.data_set.set("playerThrottle", 4.0,0)
            speed = 4
        else:
            ship.data_set.set("playerThrottle", 5.0,0)
            speed = 5


        # Standoff engagement: the weapons opener asks us to hold at a set range so the
        # EMP/Nuke detonate a safe distance away, not point-blank. Ease into the standoff
        # ring and hold there. Only vs a raider, never while docking/fleeing.
        standoff = get_inventory_value(_ship_id, "weapons_standoff", 0)
        if has_roles(t, "raider") and standoff > 0:
            if ln <= standoff:
                ship.data_set.set("playerThrottle", 0, 0)
                speed = 0
            elif ln <= standoff + 2000:
                ship.data_set.set("playerThrottle", 0.5, 0)
                speed = 0.5

        # Damaged steering: if we can barely turn, do NOT charge - a straight-line burn
        # just flies us off into deep space chasing a target we cannot aim at. Hold station
        # (the danger-dodge above still nudges us clear of hazards - "only move to avoid
        # attack") until the maneuver system recovers.
        if not can_turn and not go_dock:
            ship.data_set.set("playerThrottle", 0, 0)
            speed = 0

        ship.data_set.set("steerToDirDX", diff.x,0)
        ship.data_set.set("steerToDirDY", diff.y,0)
        ship.data_set.set("steerToDirDZ", diff.z,0)
        ship.data_set.set("steeringToDirFlag", 1,0)
        if last != t:
            comms_broadcast(client_id, "{ship.name} > {t.name} at {speed:.1f} Dock {last_go_dock} {ln:.0f}")
    else:
        # Anti-degeneracy: nothing to chase (no raiders/upgrades/wrecks and not
        # docking). Wander toward a roaming point so attract never looks frozen on
        # a lobby screen; pick a new point once we get near the current one.
        wander = get_inventory_value(_ship_id, "wander_target", None)
        if wander is None or (wander - ship.pos).length() < 2000:
            wander = Vec3.rand_in_sphere(8000, 25000, False, True)
            set_inventory_value(_ship_id, "wander_target", wander)
        diff = wander - ship.pos
        # Do not wander off if we cannot turn - we would just fly straight into deep space.
        _wander_throttle = 1.0
        if not can_turn:
            _wander_throttle = 0
        ship.data_set.set("playerThrottle", _wander_throttle, 0)
        ship.data_set.set("steerToDirDX", diff.x, 0)
        ship.data_set.set("steerToDirDY", diff.y, 0)
        ship.data_set.set("steerToDirDZ", diff.z, 0)
        ship.data_set.set("steeringToDirFlag", 1, 0)

    await delay_sim(1)
    jump automated_player_helm_ai

