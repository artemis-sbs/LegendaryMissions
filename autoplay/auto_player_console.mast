    #
    ##### _ship_id = sbs.get_ship_of_client(client_id) 
    # _ship_id is passed in
    ship = to_object(_ship_id)
    # End (do not loop) when our ship is gone: to_object(_ship_id) is None the tick it
    # is destroyed. Looping here would keep re-resolving the captured _ship_id forever,
