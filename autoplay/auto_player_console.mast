=== automated_player_engineering_ai
    #
    # Play engineer: overpower drive + weapons so the ship goes faster and shoots faster,
    # and balance that against heat with coolant. Ease off when energy runs low so we
    # never starve the ship. (data: _ship_id)
    #
    ship = to_object(_ship_id)
    ->END if ship is None
    ds = ship.data_set

    energy = ds.get("energy", 0) or 0
    # Target overpower level, backed off as energy drops (mirrors the helm thresholds).
    boost = 1.5
    if energy < 500:
        boost = 1.2
    if energy < 250:
        boost = 1.0

    # Walk the powered-subsystem controls by label - engine-safe range(30) scan, the same
    # idiom as set_engineering_value. Overpower drive + weapons; leave shields/sensors at
    # nominal (they do not help the attract fight and would just burn energy/heat). If the
    # ship system a control feeds is running hot, hold that control back.
    for i in range(30):
        _label = ds.get("eng_control_label", i)
        continue if _label is None or _label == ""
        low = _label.lower()
        want = 1.0
        if "impulse" in low or "warp" in low or "maneuver" in low or "jump" in low:
            want = boost
        elif "beam" in low or "torp" in low or "missile" in low:
            want = boost
        sysi = ds.get("eng_control_type_index", i) or 0
        heat = ds.get("system_cur_heat", sysi) or 0
        if heat > 0.7:
            want = 1.0
        elif heat > 0.5 and want > 1.2:
            want = 1.2
        ds.set("eng_control_value", want, i)

    # Coolant: pour the ship's available coolant onto the hottest of the 4 ship systems
    # first, so the overpowered drive/weapons stay online. Never allocate past what we carry.
    total_coolant = ds.get("system_coolant_available", 0) or 0
    remaining = total_coolant
    for si in range(4):
        heat = ds.get("system_cur_heat", si) or 0
        want = 0
        if heat > 0.25:
            want = int(total_coolant * heat)
        if want > remaining:
            want = remaining
        ds.set("system_coolant_used", want, si)
        remaining = remaining - want

    await delay_sim(2)
    jump automated_player_engineering_ai

