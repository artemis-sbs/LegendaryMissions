=== automated_player_weapons_ai
    #
    # Look for closest enemy and select it
    #
    ###_ship_id = sbs.get_ship_of_client(client_id) 
    ship = to_object(_ship_id)
    # See science AI: ->END on a gone ship rather than looping on a stale/recycled id.
    ->END if ship is None

    # Exclude wrecks from the foe/torp set - we only BEAM wrecks, never spend torps on
    # them. A just-killed raider can linger tagged, so drop anything now roled "wreck".
    _foes = side_hostile_members(_ship_id, "raider") - role("wreck")
    raider = closest(_ship_id, _foes, 10000)
    wreck = closest(_ship_id, role("wreck"), 10000)
    if raider is not None:
        rid = to_id(raider)
        rng = raider.distance
        current = get_weapons_selection(_ship_id)
        if current != rid:
            set_weapons_selection(_ship_id, rid)

        # Beams auto-fire; torpedoes need an explicit launch. Every launch below is
        # AMMO-AWARE: fire_torpedo silently falls back to tube 0 (Homing) for a type we
        # do not carry - and launches even when Homing_NUM has hit 0 - so we read the
        # real counts first and only fire a type we actually have, stepping DOWN the
        # doctrine to whatever is loaded and firing nothing when every tube is empty.
        # (That is what stopped a live, undestroyed ship spitting phantom Homing torps.)
        cluster = _foes & broad_test_around(rid, 2000, 2000, 0x30)
        nuke_num = torpedo_get_count_for_ship(_ship_id, "Nuke")[0]
        emp_num = torpedo_get_count_for_ship(_ship_id, "EMP")[0]
        homing_num = torpedo_get_count_for_ship(_ship_id, "Homing")[0]
        pshock_num = torpedo_get_count_for_ship(_ship_id, "PShock")[0]
        # Friendly-fire guard: allies (other players / allied NPCs, NOT ourselves) within
        # blast range of the target. Any area torp (Nuke/EMP) is unsafe when this is set.
        # The target itself may sit in a crowd of ENEMIES - that is fine, we only avoid
        # catching friendlies; we stand off at 5000 so we are never in our own blast.
        friends_near = side_allied_members(_ship_id) & broad_test_around(rid, 3000, 3000, 0x30)
        friends_near = friends_near - {_ship_id}
        aoe_safe = len(friends_near) == 0

        # Target shields down? (all facings depleted -> a PShock one-shots the hull)
        shields_down = False
        blob = to_blob(rid)
        if blob is not None:
            scount = blob.get("shield_count", 0) or 0
            if scount > 0:
                shields_down = True
                for s in range(scount):
                    smax = blob.get("shield_max_val", s) or 0
                    scur = blob.get("shield_val", s) or 0
                    if smax > 0 and (scur / smax) >= 0.1:
                        shields_down = False

        opener_target = get_inventory_value(_ship_id, "opener_target", 0)

        if shields_down and pshock_num > 0:
            # Shields down: PShock is the kill shot on an unshielded hull.
            fire_torpedo(_ship_id, "PShock")
        elif aoe_safe and rng >= 5000 and rng <= 10000 and opener_target != rid and (emp_num > 0 or nuke_num > 0):
            # Enemy at range (>= 5000) with no friendlies in the blast: run the EMP/Nuke
            # opener ONCE from a 5000 standoff, then close to mop up. Skipped when already
            # close, so we never Nuke point-blank and catch ourselves in the blast.
            set_inventory_value(_ship_id, "opener_target", rid)
            task_schedule(automated_player_engage_opener, {"_ship_id": _ship_id, "target_id": rid})
        elif aoe_safe and len(cluster) >= 3 and nuke_num > 0:
            fire_torpedo(_ship_id, "Nuke")
        elif aoe_safe and len(cluster) == 2 and emp_num > 0:
            fire_torpedo(_ship_id, "EMP")
        elif homing_num > 0:
            fire_torpedo(_ship_id, "Homing")
        elif emp_num > 0:
            fire_torpedo(_ship_id, "EMP")
        elif nuke_num > 0:
            fire_torpedo(_ship_id, "Nuke")
    elif wreck is not None:
        wid = to_id(wreck)
        current = get_weapons_selection(_ship_id)
        if current != wid:
            set_weapons_selection(_ship_id, wid)


# set_weapons_selection
