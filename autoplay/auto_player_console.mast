=== automated_player_engage_opener
    # Isolated-target opener. Hold the ship at a 5000u standoff (the helm reads
    # weapons_standoff), strip shields with an EMP, Nuke, then WAIT for the volley to
    # detonate before releasing the standoff and closing in to mop up. Always clears the
    # standoff before ending - even on a mid-volley target death - so the helm is never
    # left frozen. (data: _ship_id, target_id)
    ship = to_object(_ship_id)
    ->END if ship is None

    set_weapons_selection(_ship_id, target_id)
    # Hold at 5000 so the EMP/Nuke detonate well clear of us, not point-blank.
    set_inventory_value(_ship_id, "weapons_standoff", 5000)

--- opener_reach_standoff
    ->END if to_object(_ship_id) is None
    if to_object(target_id) is None:
        set_inventory_value(_ship_id, "weapons_standoff", 0)
        ->END
    if sbs.distance_id(_ship_id, target_id) > 6000:
        await delay_sim(1)
        jump opener_reach_standoff

    # At the standoff ring: EMP to strip shields, wait, then a single Nuke. Re-check for
    # friendlies in the blast before EACH launch (positions shift during the approach) and
    # hold fire if any friendly (not ourselves - we are safely out at 5000) is near the
    # target. Enemies clustered around the target are fine; we only avoid friendly fire.
    _ff = side_allied_members(_ship_id) & broad_test_around(target_id, 3000, 3000, 0x30)
    _ff = _ff - {_ship_id}
    if len(_ff) == 0 and not has_role(target_id, "wreck") and torpedo_get_count_for_ship(_ship_id, "EMP")[0] > 0:
        fire_torpedo(_ship_id, "EMP")
    await delay_sim(2)
    ->END if to_object(_ship_id) is None
    if to_object(target_id) is not None:
        _ff = side_allied_members(_ship_id) & broad_test_around(target_id, 3000, 3000, 0x30)
        _ff = _ff - {_ship_id}
        if len(_ff) == 0 and not has_role(target_id, "wreck") and torpedo_get_count_for_ship(_ship_id, "Nuke")[0] > 0:
            fire_torpedo(_ship_id, "Nuke")

    # Wait for the torps to reach the target and explode before moving in (up to ~6s;
    # break out early once the target is gone).
    for _w in range(6):
        ->END if to_object(_ship_id) is None
        if to_object(target_id) is None:
            jump opener_mop_up
        await delay_sim(1)

--- opener_mop_up
    # Release the standoff - close in and mop up with beams / Homing.
    ->END if to_object(_ship_id) is None
    set_inventory_value(_ship_id, "weapons_standoff", 0)
    ->END


=== automated_player_comms_ai
    #
    # Look for closest enemy and select it
    #
    ###_ship_id = sbs.get_ship_of_client(client_id) 
    ship = to_object(_ship_id)
    # See science AI: ->END on a gone ship rather than looping on a stale/recycled id.
    ->END if ship is None

    _foes = side_hostile_members(_ship_id, "raider")
    raider = closest(_ship_id, _foes, 10000)
    if raider is not None:
        rid = to_id(raider)
        current = get_comms_selection(_ship_id)
        if current != rid:
            set_comms_selection(_ship_id, rid)
            follow_route_select_comms(_ship_id, rid)

        # Player-like comms. Taunt the enemy with the RIGHT line - the one an intel scan
        # reveals, taunt_data[taunt_trait] - once per target (which enrages their fleet).
        taunt_list = get_inventory_value(rid, "taunt_data")
        taunt_done = get_inventory_value(rid, "taunt_attempted", False)
        taunted = get_inventory_value(_ship_id, "comms_taunted_target", 0)
        if taunt_list is not None and not taunt_done and taunted != rid:
            trait = get_inventory_value(rid, "taunt_trait", 0)
            if trait < len(taunt_list):
                set_inventory_value(_ship_id, "comms_taunted_target", rid)
                right_taunt = taunt_list[trait]
                task_schedule(handle_comms_taunt_raider_select, {"COMMS_ORIGIN_ID": _ship_id, "COMMS_SELECTED_ID": rid, "data": right_taunt, "select_right": True})

        # When the target's shields are down, hail to demand surrender - the LM handler
        # rolls the chance and messages the result. Once per target.
        surrender_asked = get_inventory_value(_ship_id, "comms_surrender_target", 0)
        if surrender_asked != rid and not has_role(rid, "surrendered") and not has_role(rid, "never_surrender"):
            _blob = to_blob(rid)
            _down = False
            if _blob is not None:
                _sc = _blob.get("shield_count", 0) or 0
                if _sc > 0:
                    _down = True
                    for _s in range(_sc):
                        _sm = _blob.get("shield_max_val", _s) or 0
                        _scur = _blob.get("shield_val", _s) or 0
                        if _sm > 0 and (_scur / _sm) >= 0.1:
                            _down = False
            if _down:
                set_inventory_value(_ship_id, "comms_surrender_target", rid)
                task_schedule(handle_comms_raider_surrender, {"COMMS_ORIGIN_ID": _ship_id, "COMMS_SELECTED_ID": rid})


    # set_weapons_selection

