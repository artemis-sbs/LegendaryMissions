=== automated_player_supervisor
    # Re-hook AI onto any player ship that has none. The per-ship AI tasks ->END when
    # their ship dies; a respawn is a NEW id with no HOOKED flag, so this picks it up.
    # Replaces the old commented-out respawn wiring.
    for player in role("__player__"):
        if not get_inventory_value(player, "AUTO_PLAY_HOOKED", False):
            task_schedule(automated_player_hook, {"_ship_id": player})
    await delay_sim(5)
    jump automated_player_supervisor

