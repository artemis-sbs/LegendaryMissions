{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build_addons",
      "type": "shell",
      "options": {
        "shell": {
          "executable": "cmd.exe",
          "args": [
            "/C" // This is important for CMD to execute the command and then close
          ]
        }
      },
      "command": "..\\sbs.pyz lib LegendaryMissions",
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "rerelease",
      "type": "shell",
      "options": {
        "shell": {
          "executable": "cmd.exe",
          "args": [
            "/C" 
          ]
        }
      },
      "command": "..\\sbs.pyz release LegendaryMissions \"Dev v1.3.0\" -u",
      "problemMatcher": [],
       "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
      "group": {
        "kind": "release",
        "isDefault": true
      }
    },
    {
      "label": "serve",
      "type": "shell",
      "options": {
        "shell": {
          "executable": "cmd.exe",
          "args": [
            "/C" 
          ]
        }
      },
      "command": "cd ..\\LegendaryMissions\\mkdocs&&mkdocs serve",
      "problemMatcher": [],
      "group": {
        "kind": "mkdocs",
        "isDefault": true
      }
    },
    {
      "label": "pub docs",
      "type": "shell",
      "options": {
        "shell": {
          "executable": "cmd.exe",
          "args": [
            "/C" // This is important for CMD to execute the command and then close
          ]
        }
      },
      "command": "cd ..\\LegendaryMissions\\mkdocs&&mkdocs gh-deploy --force",
      "problemMatcher": [],
      "group": {
        "kind": "mkdocs",
        "isDefault": true
      }
    },
    {
      // Runs the mission PLAIN (no debugpy) so MAST step-into-Python works.
      // Used as the preLaunchTask of "MAST: debug (plain, Python step-in)".
      // Background: VS Code treats it "ready" once the runner prints LISTENING.
      "label": "mast-run-plain",
      "type": "shell",
      "command": "python",
      // --use-working-tree: load sbs_utils from SOURCE, not the packaged .sbslib,
      // so Python frames point at real editable files (not a path inside the zip).
      "args": ["-m", "cosmos_dev.mission_runner", ".", "--gui", "--map", "0", "--dap-port", "4711", "--dap-wait", "--use-working-tree"],
      "options": {
        "cwd": "${workspaceFolder}/../LegendaryMissions",
        "env": { "PYTHONPATH": "../sbs_utils;../../../PyAddons" }
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": [{ "regexp": "__mast_never_match__", "file": 1, "location": 1, "message": 1 }],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "\\[runner\\]",
          "endsPattern": "MAST debug adapter LISTENING"
        }
      }
    }
  ]
}