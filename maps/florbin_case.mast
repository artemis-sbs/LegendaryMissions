    jump fb_pest_messages


===== fb_check_ambassador_rescued ======
    for p in role("__player__"):
        ds1_list = to_list(role("ds1"))
        ->END if len(ds1_list) < 1
        ds1_id = ds1_list[0]
        dist = sbs.distance_id(p, ds1_id)
        p_obj = to_object(p)
        dock_status = p_obj.data_set.get("dock_state", 0)
        check_pod = get_inventory_value(p, "escape-pod", 0)
        if dock_status == "docked" and dist <= 600 and check_pod > 0:
            name = p_obj.name
            send_general_message(fb_admiral.name, mast_format_string(FB_TEXT.get("admiral_rescue")), get_face(fb_admiral.id), ds1_id)
            FB_STATUS = 5
            ->END
    await delay_sim(5)
    jump fb_check_ambassador_rescued


