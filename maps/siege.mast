    SIEGE_ACTIVE = True
    terrain_value = terrain_to_value(TERRAIN_SELECT)
    lethal_value =  terrain_to_value(LETHAL_SELECT)
    friendly_value = terrain_to_value(FRIENDLY_SELECT)
    monster_value = terrain_to_value(MONSTER_SELECT)
    upgrade_value = terrain_to_value(UPGRADE_SELECT)

    # Map size -> playable half-extent R, and a concrete key so the keyed field
    # is reproducible (0 = a fresh random map). inner = terrain/content area,
    # outer = fleet spawn area; the station slot box scales with the map too.
    default MAP_SIZE = "Medium"
    R = 50_000
    if MAP_SIZE == "Small":
        R = 35_000
    elif MAP_SIZE == "Large":
        R = 70_000
    map_key = seed_value if seed_value != 0 else random.randrange(1, 2_000_000_000)
    inner = R * 0.9
    outer = R * 1.3
    st_box = R * 1.2
    st_box_small = R * 0.4

    # Build the map in phases, each re-seeded from seed_value + a fixed offset
    # (only when a seed is set). Giving each phase its own RNG stream keeps the
    # map as consistent as possible when other options change: changing monsters,
    # lethal terrain, friendly ships, or player count no longer shifts the
    # station layout or the asteroid/nebula field, because those phases draw from
    # independent streams. (Difficulty still changes the station-slot count and
    # fleet size by design.)
    if seed_value != 0:
        random.seed(seed_value)        # phase 0: station layout

    #------------------------------------------------------------------------------------------------------------

    # Should yield 16 points
    # The stations are placed in one of these slots
    # The points are moved within the slot but stay in the slot
    # the 0.8 drift mean that the startion can drift from the center point by up to 80% of 20,000 = 16,000
    if DIFFICULTY > 7:
        # 4 slots
        spawn_points = scatter_simple_noise(0, 0, 0, 0, st_box_small, 750, st_box_small, 2, 1, 2, centered=True, drift=0.7)
    elif DIFFICULTY > 3:
        # nine slots
        spawn_points = scatter_simple_noise(0, 0, 0, 0, st_box, 750, st_box, 3, 1, 3, centered=True, drift=0.7)
    else:
        # 16  slots
        spawn_points = scatter_simple_noise(0, 0, 0, 0, st_box, 750, st_box, 4, 1, 4, centered=True, drift=0.7)

    # Add stations
    # This return the object create
    # These will be used later to prune a set of points
    stations = terrain_spawn_stations(DIFFICULTY, lethal_value, points=spawn_points)
    

    top = 50_000
    left = -50_000
    right = 50_000
    bottom = -50_000

    # Use this to see the cneter point and boundaries
    # marker_obj = terrain_spawn(0,0,0, "center", "map", "generic-sphere", "behav_selection")
    # marker_obj.data_set.set("radar_color_override", "cyan" ,0)

    # marker_obj = terrain_spawn(-50_000,0,-50_000, "bottom left", "map", "generic-sphere", "behav_selection")
    # marker_obj.data_set.set("radar_color_override", "red" ,0)
    # marker_obj = terrain_spawn(50_000,0,-50_000, "bottom right", "map", "generic-sphere", "behav_selection")
    # marker_obj.data_set.set("radar_color_override", "lime" ,0)
    # marker_obj = terrain_spawn(-50_000,0,50_000, "top left", "map", "generic-sphere", "behav_selection")
    # marker_obj.data_set.set("radar_color_override", "orange" ,0)
    # marker_obj = terrain_spawn(50_000,0,50_000, "top right", "map", "generic-sphere", "behav_selection")
    # marker_obj.data_set.set("radar_color_override", "purple" ,0)
    

    await task_schedule(spawn_friendly_npc)
    await task_schedule(spawn_players)
    await task_schedule(default_player_friendly_eyes)
    await task_schedule(docking_standard_player_station)

    # phase 1: position-keyed asteroid / nebula field. A pure function of
    # (map_key, position), so a small map is the centered subset of a large one
    # and is unaffected by friendly / player / monster / lethal choices.
    neb_chance = terrain_value * 0.0010
    ast_chance = terrain_value * 0.0008
    terrain_spawn_field_keyed(map_key, 1000, -inner, -inner, inner, inner, terrain_value, neb_chance, ast_chance, exclude=stations, exclude_radius=15_000)

    # Keyed candidate pool for pickups / monsters / black holes (clear of
    # stations). They sample the pool, so they need not match across sizes.
    if seed_value != 0:
        random.seed(seed_value + 1)
    spawn_points = scatter_grid_keyed(map_key, 2000, -outer, -outer, outer, outer, -375, 375)
    spawn_points = terrain_remove_points_near(spawn_points, stations, 15_000)
    t_spawn_points = list(terrain_random_point_box(spawn_points, -inner, -500, inner, inner, 500, -inner))
    # phase 2: pickups / upgrades
    if seed_value != 0:
        random.seed(seed_value + 2)
    # These should remove points / sample
    terrain_spawn_pickups(upgrade_value, points=t_spawn_points)
    # phase 3: monsters
    if seed_value != 0:
        random.seed(seed_value + 3)
    m_points = terrain_spawn_monsters(monster_value, points=t_spawn_points)
    t_spawn_points = terrain_remove_points_near(t_spawn_points, m_points, 7_000)
    # phase 4: black holes (lethal terrain)
    if seed_value != 0:
        random.seed(seed_value + 4)
    b_points = terrain_spawn_black_holes(lethal_value, points=t_spawn_points)
    # Remove monster and blck hole from main pool
    spawn_points = terrain_remove_points_near(spawn_points, m_points, 7_000)
    spawn_points = terrain_remove_points_near(spawn_points, b_points, 7_000)



    #------------------------------------------------------------------------------------------------------------
    # Generate Siege Fleets - These fleets are weighted towards Kraliens (based on DIFFICULTY), from 85% Kralien at DIFFICULTY 1 
    # to 22% Kralien at DIFFICULTY 10. The fleet lists can be found in 'map_common.py'. Skaraans are generated separately, as these 
    # 'independent contractors' tend to operate better on their own. The idea is to hopefully match the 'feel' of Artemis 2.x. 
    # phase 5: enemy fleets
    if seed_value != 0:
        random.seed(seed_value + 5)
    enemyTypeNameList = ["Kralien", "Torgoth", "Arvonian", "Ximni"]

    diff_weight = [ [85, 5, 5, 5], [82, 6, 6, 6], [79, 7, 7, 7], [76, 8, 8, 8], [70, 10, 10, 10], [64, 12, 12, 12], [58, 14, 14, 14], [46, 18, 18, 18], [34, 22, 22, 22], [22, 26, 26, 26], [10, 30, 30, 30]]
    
    fleet_count = 3 + int(DIFFICULTY/2)
    fleet_index = int(DIFFICULTY - 1)

    # Now try to make it so enemies don't spawn on stations
    spawn_points = terrain_remove_points_near(spawn_points, stations, 20_000)

    top = outer
    left = -outer
    right = outer
    bottom = -outer
    size = outer * 0.5

    # Create 4 spawn emitter blocks
    enemy_emitters = []
    # 1 2 3
    # 4 5 6
    # 7 8 9
    # 1
    enemy_emitters.append( terrain_random_point_box(spawn_points, left, -500, top, left+size , 500, top-size) )
    # 3
    enemy_emitters.append( terrain_random_point_box(spawn_points, right-size, -500, top, right , 500, top-size) )
    # 7
    enemy_emitters.append( terrain_random_point_box(spawn_points, left, -500, bottom+size, left+size , 500, bottom) )
    # 9
    enemy_emitters.append( terrain_random_point_box(spawn_points, right-size, -500, bottom+size, right , 500, bottom) )
    # 2
    enemy_emitters.append( terrain_random_point_box(spawn_points, left+size, -500, top, right-size, 500, top-size) )
    # 4
    enemy_emitters.append( terrain_random_point_box(spawn_points, left, -500, top-size, left+size, 500, bottom+size) )
    # 6
    enemy_emitters.append( terrain_random_point_box(spawn_points, right-size, -500, top-size, right, 500, bottom+size) )
    # 8
    enemy_emitters.append( terrain_random_point_box(spawn_points, left+size, -500, bottom+size, right-size, 500, bottom) )

    random.shuffle(enemy_emitters)
    emitters = list(enemy_emitters)
    

    # times to for skarrans
    if len(spawn_points) < fleet_count*2:
        # There should be enough points, but if not
        spawn_points = None
        
    for a in range(fleet_count):
        enemy_temp = random.choices(enemyTypeNameList, weights=diff_weight[fleet_index])
        
        enemy = enemy_temp[0]
        if spawn_points is None:
            fleet_pos = Vec3.rand_in_sphere(39990, 40000, False, True)
            debug_print("Wrong spawn")
        else:
            if len(emitters)==0:
                debug_print("Shuffle")
                random.shuffle(enemy_emitters)
                emitters = list(enemy_emitters)
            em = emitters.pop()
            # Get the next random point from teh emitter
            fleet_pos = next(em, None)
        
        if fleet_pos is None:
            fleet_pos = Vec3.rand_in_sphere(39990, 40000, False, True)
            debug_print("FLEET POS out of points?")

        prefab_spawn(prefab_fleet_raider, {"race": enemy, "fleet_difficulty": DIFFICULTY,"START_X": fleet_pos.x, "START_Y": fleet_pos.y, "START_Z": fleet_pos.z})
        if a > 1 and DIFFICULTY > 2:
            if spawn_points is None:
                fleet_pos = Vec3.rand_in_sphere(39990, 40000, False, True)
            else:
                # Rotate emitters reshuffle after each has been used
                if len(emitters)==0:
                    random.shuffle(enemy_emitters)
                    emitters = list(enemy_emitters)
                    print("Shuffle 2")
                em = emitters.pop()
                # Get the next random point from teh emitter
                fleet_pos = next(em, None)

            if fleet_pos is None:
                fleet_pos = Vec3.rand_in_sphere(39990, 40000, False, True)
                debug_print("FLEET POS out of points?")
        
            prefab_spawn(prefab_fleet_raider, {"race": "Skaraan", "fleet_difficulty": DIFFICULTY, "START_X": fleet_pos.x, "START_Y": fleet_pos.y, "START_Z": fleet_pos.z})

    #------------------------------------------------------------------------------------------------------------

    # End-game as quests, authored in maps/siege_quests.amd (the shared AMD quest
    # vocabulary - the same grammar Open Universe uses). A SHARED mission quest whose
    # children drive win/lose: break_siege (Required) completes on siege_won; the two
    # Critical children each fire the loss with their own reason text. siege_watch
    # below translates live board state into those signals, so win/lose flows through
    # the quest system (and shows on the results log), not a bespoke poll.
    # (task_end_game is left for the other maps that still use it.)
    quest_grant_amd(SHARED, document_get_amd_file(get_mission_dir_filename("maps/siege_quests.amd"), data_parser=amd_quest_data))
    task_schedule(siege_watch)
    task_schedule(siege_bonus_objectives)
    # A "continuous" boss (Trigger: continuous) keeps respawning waves from the start
    # until the clock runs out (convention play). A one-shot boss (Trigger:
    # enemies_low) instead arrives via siege_watch's siege_enemies_low.
    if siege_boss_trigger(BOSS_SELECT) == "continuous":
        task_schedule(siege_continuous)

    #------------------------------------------------------------------------------------------------------------


#
# Optional siege bonus objectives (lean - reuses the quest driver for rewards):
#  - Ace: rack up raider kills (per-player, on_kill).
#  - Guardian: finish without losing a starbase (fails on station loss; completes
#    at game end via the siege_survived signal).
#
=== siege_bonus_objectives
    # More achievable + difficulty-scaled: base 6 raiders at DIFFICULTY 5 (was
    # 8+DIFFICULTY = 13), fewer on easy, more on hard, never below 3.
    ace_target = quest_kill_count_for_difficulty(6, DIFFICULTY, floor=3)
    for p in to_object_list(role("__player__")):
        quest_add(p.id, "siege_ace", f"Ace: {ace_target} raider kills", f"Optional: destroy {ace_target} raiders this siege.", state=1, data={"on_kill": {"role": "raider", "count": ace_target}, "reward": {"credits": 300, "items": {"tech": 1}}})
        quest_add(p.id, "siege_guardian", "Guardian: keep every starbase", "Optional: finish the siege without losing a starbase.", state=1, data={"on_signal": {"name": "siege_survived"}, "reward": {"credits": 500}})
    ->END


# Lifecycle watcher: translate live board state into the siege_mission signals.
# It no longer ends the game itself - the quest system does (game_over route),
# so the outcome + its reason text come from the mission quest.
=== siege_watch
    default GAME_ENDED = False
    default shared SIEGE_TIMEOUT = "Win"
    default shared BOSS_SELECT = "None"
    seen_raiders = False
    peak_raiders = 0
    boss_triggered = False
--- loop
    await delay_sim(4)
    ->END if GAME_ENDED
    raider_count = len(role("raider"))
    if raider_count > peak_raiders:
        peak_raiders = raider_count
    if raider_count > 0:
        seen_raiders = True
    # Boss: once the raiders thin below the selected boss's Low threshold, the boss
    # arrives (its forces + objectives, config from maps/bosses/). Fires once.
    if seen_raiders and not boss_triggered and BOSS_SELECT != "None":
        if raider_count <= peak_raiders * siege_boss_low_pct(BOSS_SELECT):
            boss_triggered = True
            signal_emit("siege_enemies_low", None)
    # Lose: every friendly starbase is gone.
    if len(role("tsn") & role("station")) == 0:
        signal_emit("quest_signal", {"SIGNAL_NAME": "siege_bases_lost"})
        ->END
    # Win: the fleets are cleared (only once they actually turned up, so a first
    # tick before the fleets finish spawning can't declare an instant victory). A
    # boss adds raider-roled forces, so this waits for them too.
    if seen_raiders and raider_count == 0:
        signal_emit("quest_signal", {"SIGNAL_NAME": "siege_won"})
        ->END
    # Time limit reached: the outcome is the "Survive Clock" map option.
    if is_timer_set(SHARED, "time_limit") and is_timer_finished(SHARED, "time_limit"):
        remove_role(role("raider"), "raider")
        if SIEGE_TIMEOUT == "Loss":
            signal_emit("quest_signal", {"SIGNAL_NAME": "siege_time_lost"})
        else:
            signal_emit("quest_signal", {"SIGNAL_NAME": "siege_won"})
        ->END
    jump loop


# The selected boss arrives when the raiders thin out: spawn its reinforcement
# fleets + named flagships (config from maps/bosses/, folder-scanned) and graft its
# objectives onto siege_mission. Config-driven - a new boss .amd needs no change here.
//signal/siege_enemies_low if BOSS_SELECT != "None"
    # Only one-shot bosses arrive this way; a continuous boss runs its own wave loop.
    ->END if siege_boss_trigger(BOSS_SELECT) != "enemies_low"
    boss_node = siege_boss_get(BOSS_SELECT)
    ->END if boss_node is None
    boss_race = siege_boss_race(BOSS_SELECT)
    boss_diff = siege_boss_difficulty(BOSS_SELECT, DIFFICULTY)
    for boss_i in range(siege_boss_fleet_count(BOSS_SELECT)):
        fpos = Vec3.rand_in_sphere(25000, 45000, False, True)
        prefab_spawn(prefab_fleet_raider, {"race": boss_race, "fleet_difficulty": boss_diff, "ship_roles": "raider, boss_fleet", "START_X": fpos.x, "START_Y": fpos.y, "START_Z": fpos.z})
    for boss_name, boss_art in siege_boss_named(BOSS_SELECT):
        npos = Vec3.rand_in_sphere(20000, 30000, False, True)
        boss_roles = "raider, boss, " + boss_name.lower()
        prefab_spawn(prefab_siege_boss_ship, {"START_X": npos.x, "START_Y": npos.y, "START_Z": npos.z, "NAME": boss_name, "BOSS_ART": boss_art, "BOSS_ROLES": boss_roles})
    quest_grant_amd(SHARED, boss_node)
    # A boss with a Hook runs a bespoke behavior label (e.g. the infestation loop).
    if siege_boss_hook(BOSS_SELECT) != "":
        prefab_spawn(siege_boss_hook(BOSS_SELECT), {"BOSS_SELECT": BOSS_SELECT})
    ->END


# A named boss flagship: a durable hull that hunts players + stations. prefab_spawn
# seeds NAME / BOSS_ART / BOSS_ROLES as task vars; the brain metadata is the tree.
=== prefab_siege_boss_ship
metadata: ```
brain:
    - label: ai_chase_player
      data:
        force_shoot: true
        throttle: 2.0
    - label: ai_chase_station
      data:
        force_shoot: true
        throttle: 1.6
```
    boss_ship = npc_spawn(START_X, START_Y, START_Z, NAME, BOSS_ROLES, BOSS_ART, "behav_npcship")
    brain_add(boss_ship, brain)
    yield result to_id(boss_ship)


# Continuous boss: respawn waves from the start until the clock nears its end, then
# the attackers break off (surrender) for a satisfying defender win. Config from the
# selected boss .amd (Flies race / Fleets per wave / Difficulty / Wave seconds).
=== siege_continuous
    default shared BOSS_SELECT = "None"
    default GAME_ENDED = False
    cont_wave = siege_boss_wave(BOSS_SELECT)
    cont_diff = siege_boss_difficulty(BOSS_SELECT, DIFFICULTY)
    cont_count = max(1, siege_boss_fleet_count(BOSS_SELECT))
    cont_end = safe_int(GAME_TIME_LIMIT) * 60 * 0.02
--- cwave
    await delay_sim(cont_wave)
    ->END if GAME_ENDED
    # Within the last ~2% of the time limit the raiders break off and retreat.
    if is_timer_set(SHARED, "time_limit") and get_time_remaining(SHARED, "time_limit") < cont_end:
        jump csurrender
    for cont_i in range(cont_count):
        wpos = Vec3.rand_in_sphere(30000, 45000, False, True)
        prefab_spawn(prefab_fleet_raider, {"race": siege_boss_race(BOSS_SELECT), "fleet_difficulty": cont_diff, "ship_roles": "raider, continuous", "START_X": wpos.x, "START_Y": wpos.y, "START_Z": wpos.z})
    jump cwave
--- csurrender
    # Randomized retreat chatter, then the attackers flee (drop the raider role, so
    # siege_watch declares siege_won once they are gone).
    surrender_lines = ~~["This is too much - all ships retreat!", "Fall back! We can't break them!", "Break off! Break off!", "Signal the withdrawal - now!"]~~
    comms_broadcast(role("__player__"), random.choice(surrender_lines), "#fa0")
    remove_role(role("raider"), "raider")
    ->END


# A starbase fell: the Guardian bonus is lost for everyone. KILLED (not DESTROY):
# the station is still registered here, so has_role reads it (a destroyed object is
# often already gone on the DESTROY route). Victim = DAMAGE_SELECTED_ID.
//damage/killed if SIEGE_ACTIVE and has_role(DAMAGE_SELECTED_ID, "station")
    for p in to_object_list(role("__player__")):
        quest_mark_failed(p.id, "siege_guardian")
    ->END


# Game over: any still-active Guardian bonus survived - complete it.
//signal/show_game_results if SIEGE_ACTIVE
    signal_emit("quest_signal", {"SIGNAL_NAME": "siege_survived"})
    ->END


# Ragnarok boss: XORN can be talked into defecting. Hail the light cruiser and appeal
# to their honor - XORN switches to your side and turns its guns on Ragnarok. The
# "Turn Xorn" objective listens for the xorn_defected signal this fires.
//comms if SIEGE_ACTIVE and has_any_role(COMMS_ORIGIN_ID, "__player__") and has_role(COMMS_SELECTED_ID, "xorn") and not has_role(COMMS_SELECTED_ID, "defected")
    + "Appeal to Xorn: turn on Ragnarok":
        <<[cyan] "XORN"
            % Ragnarok led us to ruin. I am done taking orders - point me at the flagship.
            % You speak true. Ragnarok betrayed the fleet. I am yours; I will take the juggernaut myself.
        # XORN switches to the player's side and hunts its former masters (Ragnarok's
        # raiders are now its enemies); a fresh chase-npc brain drives it.
        remove_role(COMMS_SELECTED_ID, "raider")
        add_role(COMMS_SELECTED_ID, "defected")
        COMMS_SELECTED.side = COMMS_ORIGIN.side
        brain_clear(COMMS_SELECTED_ID)
        brain_add(COMMS_SELECTED_ID, "ai_chase_npc", {"force_shoot": True, "throttle": 2.2})
        signal_emit("quest_signal", {"SIGNAL_NAME": "xorn_defected"})


# Infestation hook: BioMechs boil out (Cosmos approximation - the engine has no
# built-in biomech AI). They evolve (biomech_a..d, art carries the escalating stats)
# and, once one matures to Stage 4, breed litters of Stage 1 - bounded by a cap and a
# fixed number of cycles so the swarm stays winnable. Exterminate them (raider-roled)
# to win via siege_won. Scheduled by the enemies_low driver for a Hook: boss.
=== siege_boss_infestation
    default GAME_ENDED = False
    default DIFFICULTY = 5
    bio_cycles = 10
    bio_cap = 12 + int(DIFFICULTY)
    # Initial swarm; the ~20 "of all stages" builds up as they evolve and breed.
    for bio_i in range(8):
        bpos = Vec3.rand_in_sphere(20000, 40000, False, True)
        prefab_spawn(prefab_biomech, {"START_X": bpos.x, "START_Y": bpos.y, "START_Z": bpos.z, "BIO_ART": "biomech_a", "BIO_ROLES": "biomech, raider, boss"})
--- bio_grow
    await delay_sim(25)
    ->END if GAME_ENDED
    ->END if bio_cycles <= 0
    bio_cycles = bio_cycles - 1
    # Evolve a couple toward Stage 4 (the Cosmos stand-in for eating asteroids).
    siege_infestation_evolve()
    siege_infestation_evolve()
    # Breed once a Stage 4 exists and we are under the population cap.
    if siege_infestation_has_stage4() and siege_infestation_count() < bio_cap:
        rpos = Vec3.rand_in_sphere(15000, 35000, False, True)
        prefab_spawn(prefab_biomech, {"START_X": rpos.x, "START_Y": rpos.y, "START_Z": rpos.z, "BIO_ART": "biomech_a", "BIO_ROLES": "biomech, raider, boss"})
        prefab_spawn(prefab_biomech, {"START_X": rpos.x + 2500, "START_Y": rpos.y, "START_Z": rpos.z, "BIO_ART": "biomech_a", "BIO_ROLES": "biomech, raider, boss"})
    jump bio_grow

