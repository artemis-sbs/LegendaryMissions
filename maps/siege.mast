# Gate the siege bonus-objective routes to this map only.
default shared SIEGE_ACTIVE = False
# Survive-to-timeout outcome (map option): "Win" = outlasting the clock is a
# victory (today's behavior); "Loss" = failing to break the siege in time loses.
default shared SIEGE_TIMEOUT = "Win"
# Boss (map option): a boss from maps/bosses/*.amd (folder-scanned) that arrives when
# the raiders thin out (siege_enemies_low), or None. BOSS_LIST feeds the dropdown.
default shared BOSS_SELECT = "None"
default shared BOSS_LIST = siege_boss_list()

@map/siege "Siege"
" In this scenario, bases will be located in the center of the sector, 
" with minefields ringing the center, and enemies advancing from every 
" angle. Siege makes for a fast game, where stations are continually under threat.
metadata:``` yaml
Properties:
