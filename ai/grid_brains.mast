=== upgrade_damcon_inc_hp
metadata: ``` yaml
type: upgrade/damcons
```
    hp = get_inventory_value(UPGRADE_AGENT_ID, "HP", 0)
    max_hp = get_inventory_value(UPGRADE_AGENT_ID, "HP_MAX", 6)
    # hp = min(HP_MAX, hp+1)
    # set_inventory_value(AGENT_ID, "HP", hp)
    hp += 1
    yield success if hp==max_hp

    ship = UPGRADE_AGENT.host_id # obj defined in previous labels
    hp %= (max_hp+1)
    grid_set_hp(ship, UPGRADE_AGENT_ID, hp)

    if hp < max_hp:
        comms_broadcast(ship, f"{UPGRADE_AGENT.name} recovering {hp}", "blue")
        # Allow it to go again
        start_counter(UPGRADE_AGENT_ID, "idle_boost_counter")
    else:
        color = get_inventory_value(BRAIN_AGENT_ID, "color", "purple")
        go_blob = to_blob(UPGRADE_AGENT_ID)
        if go_blob is not None:
            go_blob.set("icon_color", color)
        comms_broadcast(ship, f"{UPGRADE_AGENT.name} fully recovered", "green")
    yield success


=== upgrade_damcon_speed_idle
metadata: ``` yaml
type: upgrade/damcons
dataset: move_speed
```
    #@arg: The message to present 
    default message = "Whoo good workout."
    #@arg: The duration  the boost lasts
    default time = random.randint(10,16)
    #@arg: The duration  the boost lasts
    default name = "ripped"

    speed_mods = UPGRADE_AGENT.get_inventory_value("speed_modifiers", {})
    mod = speed_mods.get(name)
    yield fail if mod is not None and not mod.expired()
    grid_short_status(UPGRADE_AGENT_ID, message, "blue", seconds=3)
    mod = modifier_add(UPGRADE_AGENT_ID, "move_speed", 0.25, name,2, time*60)
    # Modifiers returns an empty set if the mod exists?
    yield fail if isinstance(mod,set) and len(mod)==0
        
    speed_mods[name] = mod
    UPGRADE_AGENT.set_inventory_value("speed_modifiers", speed_mods)
    yield success


