=== ai_lifeform_move_to_location
# metadata: ``` yaml
# ```
    _pos = get_inventory_value(BRAIN_AGENT_ID, "blackboard:target_pos")
    prev_pos = get_inventory_value(BRAIN_AGENT_ID, "blackboard:prev_target_pos")
    idle_pos = get_inventory_value(BRAIN_AGENT_ID, "blackboard:idle_pos")
    yield fail if _pos is None
    # Have we reached it
    length = BRAIN_AGENT.data_set.get("path_length",0)
    if prev_pos is not None and length is not None and length < 0.01:
        set_inventory_value(BRAIN_AGENT_ID, "blackboard:prev_target_pos", None)
        set_inventory_value(BRAIN_AGENT_ID, "blackboard:idle_pos", _pos)
        BRAIN_AGENT.set_inventory_value("idle_state", "stopped")
        grid_damcons_detailed_status_update(BRAIN_AGENT_ID, f"Idling at {_pos[0]},{_pos[1]}", "blue", 3)
        yield fail
    
    yield success if _pos == prev_pos
    # Already been here
    yield fail if _pos == idle_pos
    # speed = grid_calc_speed(BRAIN_AGENT_ID)
    BRAIN_AGENT.set_inventory_value("idle_room", None)
    set_inventory_value(BRAIN_AGENT_ID, "blackboard:prev_target_pos", _pos)
    set_inventory_value(BRAIN_AGENT_ID, "blackboard:idle_pos", None)
    BRAIN_AGENT.set_inventory_value("idle_state", "moving")
    grid_target_pos(BRAIN_AGENT_ID, _pos[0], _pos[1], None)
    grid_damcons_detailed_status_update(BRAIN_AGENT_ID, f"Heading to location {_pos[0]},{_pos[1]}", "blue", 3)
    yield success


=== ai_idle_at_room
metadata: ``` yaml
room: __damaged__
upgrade: ai_fix_damage
idle_time: 60
hp_speed_up: False
```
    # A list of rooms type is expected
    default rooms = []
    # Verify everything is still valid
    yield fail if to_object(BRAIN_AGENT.host_id) is None
    hm = sbs.get_hull_map(BRAIN_AGENT.host_id)
    yield fail if hm is None
    idle_state = BRAIN_AGENT.get_inventory_value("idle_state")
    yield fail if idle_state == "done"
    
    # 
    x = BRAIN_AGENT.data_set.get("curx",0)
    y = BRAIN_AGENT.data_set.get("cury",0)
    #percent = BRAIN_AGENT.data_set.get("percent",0)
    #yield fail if percent > 0.001

    _pos = get_inventory_value(BRAIN_AGENT_ID, "blackboard:boost_pos", (-1,-1))
    # Are we at the idle pos
    idle_pos = get_inventory_value(BRAIN_AGENT_ID, "blackboard:idle_pos", (-2,-2))
    yield fail if x != idle_pos[0] or y != idle_pos[1]

    # See if we're at the same boost location
    new_location = idle_pos[0] != _pos[0] or idle_pos[1] != _pos[1]
        
    # Set the idle_room
    if new_location:
        current_room_ids = set(hm.get_objects_at_point(x,y))
        set_inventory_value(BRAIN_AGENT_ID, "blackboard:boost_pos", (x,y))
        #
        # Search through each room type to find the active room
        #
        this_room = None
        this_room_data = None
        for room_data in rooms:
            room_type = room_data.get("room")
            continue if room_type is None
            boost_here = current_room_ids & role(room_type)
            if len(boost_here) != 0:
                this_room = list(boost_here)
                this_room = this_room[0]
                this_room_data = room_data
                break
        # No room boost found
        yield fail if this_room is None

        set_inventory_value(BRAIN_AGENT_ID, "blackboard:boost_pos", (x,y))
        BRAIN_AGENT.set_inventory_value("idle_room", this_room)
        BRAIN_AGENT.set_inventory_value("idle_room_data", this_room_data)
        BRAIN_AGENT.set_inventory_value("idle_state", "idling")
        start_counter(BRAIN_AGENT_ID, "idle_boost_counter")
        set_timer(BRAIN_AGENT_ID, "idle_boost_timer", idle_time)
        yield success

    
    this_room = BRAIN_AGENT.get_inventory_value("idle_room")
    room_data = BRAIN_AGENT.get_inventory_value("idle_room_data")
    yield fail if this_room is None or room_data is None
    # It is OK if there in no hp speedup 
    hp_speed_up = room_data.get("hp_speed_up")
    #idle_time = room_data.get("idle_time",idle_time)
    # HP Speed up changes over time if HP change
    # this could make the boost time display wrong
    target_time = idle_time
    if is_dev_build():
        target_time = 10
    if hp_speed_up:
        hp = BRAIN_AGENT.get_inventory_value("HP", 1)
        target_time /= hp
    elapsed = get_counter_elapsed_seconds(BRAIN_AGENT_ID, "idle_boost_counter")
    # Success but keep running
    yield success if elapsed < target_time
    # Some upgrade are dict, but upgrade_handles that
    upgrade = room_data.get("upgrade")
    yield fail if upgrade is None
    upgrade_add(BRAIN_AGENT_ID, upgrade, {"ROOM_ID": this_room, "type": room}, True)
    BRAIN_AGENT.set_inventory_value("idle_state", "done")
    # We fail so other things can run
    yield fail

=== ai_grid_moving
    percent = BRAIN_AGENT.data_set.get("percent",0)
    length = BRAIN_AGENT.data_set.get("path_length",0)
    BRAIN_AGENT.set_inventory_value("idle_state", "stopped")
    yield fail if length is None or percent is None
    # This is how the engine checks as well
    yield fail length > 0 or percent >= 1
    BRAIN_AGENT.set_inventory_value("idle_state", "moving")
    yield success



