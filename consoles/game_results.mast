        gui_hole(5)
        """color:yellow;justify: left;$text:{DIFFICULTY}"""
        gui_row()
        gui_hole(5)
        """color:yellow; justify: right;$text:Enemies destroyed"""
        gui_blank(style="col-width: 1;")
        gui_hole(5)
        """color:yellow;justify: left;$text:{totals["kills"]}"""
