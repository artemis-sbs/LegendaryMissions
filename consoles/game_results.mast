#
# Game Data
#

shared game_stats = ~~{
    "tsn_destroyed": 0,
    "kralien_ships_destroyed": 0,
    "skaraan_ships_destroyed": 0,
    "arvonian_ships_destroyed": 0,
    "torgoth_ships_destroyed": 0,
    "ximni_ships_destroyed": 0,
    "ships_surrender": 0,
    "start_time": sim.time_tick_counter
}~~


//damage/killed if not has_role(DAMAGE_SELECTED_ID, "standby")
    #
    # A ship killed by damage. This is the KILLED route, not the DESTROY route:
    # killed fires "about to be removed" - the victim is still registered (its
    # side/hull read cleanly for the tally + tonnage) and the attacker rides the
    # damage event (DAMAGE_PARENT/SOURCE). The DESTROY route is a lifetime REMOVAL
    # event: it also fires for script deletes (e.g. unused player slots, which is
    # why it used to over-count) and the victim can already be gone (to_object ->
    # None -> tonnage 0). The victim here is DAMAGE_SELECTED_ID.
    #
    obj = to_object(DAMAGE_SELECTED_ID)
    if obj is not None:
        side = "{obj.side.lower()}_destroyed"
        count = game_stats.get(side, 0)
        game_stats[side] = count + 1

        race = obj.art_id
        under = race.find("_")
        if under>=0:
            race = race[0:under]
            if race=="xim":
                race= "ximni"

            race = "{race.lower()}_ships_destroyed"
            count = game_stats.get(race, 0)
            game_stats[race] = count + 1

    # Credit the kill + the victim's tonnage to the player BRIDGE ship that landed
    # the final blow. (Fighter/shuttle kills are credited by the hangar addon, so a
    # console-less mission still tracks pilots and the two never double-count.)
    # //damage/killed always carries the attacker in DAMAGE_PARENT/SOURCE.
    results_credit_kill(DAMAGE_PARENT_ID, DAMAGE_SOURCE_ID, DAMAGE_SELECTED_ID)
    ->END


# Option-B "impact" stat: accumulate raw damage dealt per player BRIDGE ship.
# Filtered to player attackers so the per-hit body stays cheap, and gated by
# TRACK_DAMAGE so a host on weak hardware can switch it off. (//damage/object is
# already routed by other addons, so this adds a handler, not new per-frame
# dispatch.)
//damage/object if SETTINGS.get("TRACK_DAMAGE", True) and (has_role(DAMAGE_PARENT_ID, "__player__") or has_role(DAMAGE_SOURCE_ID, "__player__"))
    results_credit_damage(DAMAGE_PARENT_ID, DAMAGE_SOURCE_ID, EVENT.sub_float)
    ->END


//signal/show_game_results


    sim_pause()

    GAME_ENDED = True
    START_TEXT = START_TEXT.strip()
    if START_TEXT == "":
        START_TEXT = "Game Over"
    task_schedule(save_game_results_yaml)
    gui_task_jump(show_game_results_gui)


=== show_game_results_gui

    # Tabbed results: a lean Summary lands first (same for every console); Fleet,
    # Air Wing, Quests and the per-race Enemies breakdown are one click away. The
    # selected tab is held in RESULTS_TAB (default keeps it across the re-jump each
    # tab button does).
    default RESULTS_TAB = "summary"

    mission = get_mission_name()
    start_mission = get_startup_mission_name()
    if start_mission is not None:
        same = mission == start_mission
    if start_mission is None or start_mission=="":
        same = True
        start_mission = mission
    show_replay = IS_SERVER or CONSOLE_SELECT == "operator" or CONSOLE_SELECT == "gamemaster"

    end_time = int((sim.time_tick_counter - game_stats["start_time"]) / 30  /60)
    totals = results_summary()

    # Tab strip (key, label) for this screen, drawn by the reusable gui_screen_tabs
    # helper which styles plain buttons like the console top tabs.
    results_tabs = [["summary","Summary"], ["fleet","Fleet"], ["airwing","Air Wing"], ["quests","Quests"], ["enemies","Enemies"]]

    # Top tab strip (styled like the console top tabs)
    gui_section(style="area: 40, 0, 100, 5;")
    gui_row("row-height:35px;")
    gui_screen_tabs(results_tabs, RESULTS_TAB, "results_set_tab")

    # Title band
    gui_section(style="area: 10, 6, 90, 16;")
    """color:white;justify: center; font: gui-6;$text:Game results"""
    gui_row()
    """""color:cyan;justify:center;font:gui-5;$text:{START_TEXT}"""""

    # Active tab content
    gui_section(style="area: 10, 17, 90, 90;")

    if RESULTS_TAB == "summary":
        gui_row()
        gui_hole(5)
        """color:yellow; justify: right;$text:Difficulty"""
