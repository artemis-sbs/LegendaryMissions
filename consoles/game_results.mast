    if RESULTS_TAB == "fleet":
        fleet_box = gui_list_box(results_ship_items(), "padding:0,0,10px,0;", item_template=results_ship_template, title_template=results_ship_title_template, select=False)

    if RESULTS_TAB == "airwing":
