        """color:yellow;justify: left;$text:{game_stats["ships_surrender"]}"""

    await gui():
        + "replay" if show_replay:
            sbs.run_next_mission(mission)
        + "run startup" if not same:
            sbs.run_next_mission(start_mission)

    # Kind of need to restart, which is good for now since cleanup is not guaranteed


=== results_set_tab
    # A results tab was clicked: gui_screen_tabs set TAB_KEY; record it and rebuild.
    RESULTS_TAB = TAB_KEY
    jump show_game_results_gui


=== save_game_results_yaml
    #
    # Append this game's outcome + stats to a YAML file (one record per completed
    # game) in the Artemis data dir. Useful for soak / overnight runs - the record
    # count is the number of games played - and for reviewing balance over time.
    # Runs in its own task and is best-effort, so a write error never blocks the
    # results screen. Guarded by a shared flag so a double-emitted signal saves once
    # (the flag resets naturally when run_next_mission reloads shared state).
    #
    default shared RESULTS_SAVED = False
    ->END if RESULTS_SAVED
    RESULTS_SAVED = True

    # Keep only the most recent games so the file stays small and quick to open.
    # Records now carry the dense per-ship / per-pilot / quest breakdown (more than
    # the GUI shows), so each is a few KiB and scales with crew/quest count - lower
    # this if the file gets large.
    default shared GAME_RESULTS_MAX = 200

    results_file = get_missions_dir() + "/game_results.yaml"
    results = load_yaml_data(results_file)
    if results is None or not isinstance(results, list):
        results = []

    end_ticks = sim.time_tick_counter - game_stats.get("start_time", sim.time_tick_counter)
    # Timestamp comes from a python helper (results_helpers.py): datetime's strftime
    # can't run inside MAST's restricted-builtins eval, but a module function can.
    stamp = game_results_timestamp()
    default WORLD_SELECT = None
    map_name = game_results_map(WORLD_SELECT)
    # Dense breakdown (per-ship / per-pilot / quest) the GUI omits - kept in the save.
    extra = results_record_extra()
    record = ~~{
        "time": stamp,
        "mission": get_mission_name(),
        "map": map_name,
        "outcome": START_TEXT,
        "difficulty": DIFFICULTY,
        "game_minutes": int(end_ticks / 30 / 60),
        # drop start_time (an internal sim-tick marker, not a stat; game_minutes covers duration)
        "stats": {k: v for k, v in game_stats.items() if k != "start_time"},
        "summary": extra["summary"],
        "ships": extra["ships"],
        "pilots": extra["pilots"],
        "quests": extra["quests"],
    }~~
    results.append(record)
    if len(results) > GAME_RESULTS_MAX:
        results = results[-GAME_RESULTS_MAX:]
    save_yaml_data(results_file, results)
    log(f"game results saved ({len(results)} games) -> {results_file}", "game_results")
    ->END

//signal/show_game_results if SETTINGS.get("AUTO_START")
    # Wall-clock delay (delay_app, not delay_sim): the sim is paused at game end,
    # so sim time is frozen and delay_sim would never fire.
    await delay_app(SETTINGS.get("AUTO_START_DELAY", 10))
    mission = get_mission_name()
    sbs.run_next_mission(mission)
